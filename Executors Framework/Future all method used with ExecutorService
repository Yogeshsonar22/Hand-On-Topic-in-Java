import java.util.*;
import java.util.concurrent.*;

public class Main {

    public static void main(String[] args) throws Exception {

        ExecutorService service = Executors.newFixedThreadPool(2);

        Future<Integer> future = service.submit(() -> 10 * 10);

        System.out.println("isDone before get : " + future.isDone());

        System.out.println("Result : " + future.get());   // get value

        System.out.println("isDone after get : " + future.isDone());

        System.out.println("isCancelled before : " + future.isCancelled());

        future.cancel(true);   // cancel task (after complete = false)

        System.out.println("isCancelled after : " + future.isCancelled());

        service.shutdown();
    }
}

/* output
isDone before get : false
Result : 100
isDone after get : true
isCancelled before : false
isCancelled after : false

*/
