//or with try catch blog 
import java.io.*;

public class Main {

    public static void main(String[] args) {

        try {

            FileWriter fw = new FileWriter("demo.txt");

            fw.write("Hello File Handling");

            fw.close();

            System.out.println("File Written Successfully");

        } catch (Exception e) {

            System.out.println("Error: " + e);
        }
    }
}
